# ---- Realm / DNS ----
KRB5_REALM=EXAMPLE.COM
KRB5_KDC_HOSTNAME=kdc.example.com
KRB5_DOMAIN=example.com

# ---- External OpenLDAP backend ----
# Space-separated list; prefer ldaps:// (TLS) toward the directory.
LDAP_SERVERS=ldaps://ldap.example.com
LDAP_KERBEROS_CONTAINER_DN=cn=krbContainer,dc=example,dc=com

# Service account used by krb5kdc (read-only on the Kerberos container)
LDAP_KDC_DN=cn=kdc-service,ou=services,dc=example,dc=com
LDAP_KDC_PASSWORD=change-me-kdc

# Service account used by kadmind (read-write on the Kerberos container)
LDAP_KADMIN_DN=cn=kadmin-service,ou=services,dc=example,dc=com
LDAP_KADMIN_PASSWORD=change-me-kadmin

# ---- KDB master key (encrypts principal keys stored in LDAP) ----
KRB5_MASTER_PASSWORD=change-me-master

# ---- First-boot provisioning (set to true ONCE to create the realm) ----
KRB5_CREATE_REALM=false
LDAP_ADMIN_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_PASSWORD=change-me-admin
LDAP_SUBTREES=ou=people,dc=example,dc=com

# ---- Optional tuning ----
#DNS_LOOKUP_KDC=false
#DNS_LOOKUP_REALM=false
#KRB5_MAX_LIFE=24h 0m 0s
#KRB5_MAX_RENEWABLE_LIFE=7d 0h 0m 0s
#KRB5_SUPPORTED_ENCTYPES=aes256-cts-hmac-sha1-96:normal aes128-cts-hmac-sha1-96:normal
